{
  "_comment": "Experimental config for TASK_06 (4x1 vs 2x2 workers). Identical to prod_like.json except for docling_serve_env. Do not use for the TASK_02 baseline — baseline is prod_like.",

  "docling_version": "2.88.0",
  "docling_serve_version": "1.16.1+683eeca",

  "docling_serve_env": {
    "UVICORN_WORKERS": "4",
    "DOCLING_SERVE_ENG_LOC_NUM_WORKERS": "1"
  },

  "request_form": {
    "from_formats": ["pdf", "docx"],
    "to_formats": ["md"],
    "do_ocr": "false",
    "image_export_mode": "placeholder",
    "pipeline": "standard",
    "do_picture_description": "true",
    "do_picture_description_custom": "false",
    "do_picture_classification": "false",
    "return_as_file": "false"
  },

  "picture_description_api": {
    "url": "http://mock-vlm:4000/v1/chat/completions",
    "headers": {
      "Authorization": "Bearer mock"
    },
    "params": {
      "model": "mock-vlm",
      "chat_template_kwargs": {"enable_thinking": false}
    },
    "timeout": 300,
    "concurrency": 8,
    "prompt": "Describe this image in detail.\n/no_think"
  }
}
